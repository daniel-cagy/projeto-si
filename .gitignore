# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables and local secrets
.env
.env.*
!.env.example

# Build and packaging
build/
dist/
*.egg-info/
.eggs/

# Test and coverage output
.pytest_cache/
.coverage
htmlcov/

# Type checker and linter caches
.mypy_cache/
.ruff_cache/
.pyre/

# IDE/editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Local generated outputs
resultado.json
output.json
outputs/

# Ignore test images and results, but keep .gitkeep files
tests/images/*
!tests/images/.gitkeep
tests/results/*
!tests/results/.gitkeep
